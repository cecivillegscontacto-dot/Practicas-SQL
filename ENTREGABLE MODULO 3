-- ── SECCIÓN DDL (Data Definition Language) ──────────────────────────

-- Paso 1: Limpieza preventiva del entorno para re-ejecución
DROP TABLE IF EXISTS inventario;

-- Paso 2: Creación de la estructura de la tabla
CREATE TABLE inventario (
    id_producto INT PRIMARY KEY,              -- INT: Clave primaria única y secuencial para identificación directa del producto.
    nombre_producto VARCHAR(100) NOT NULL,    -- VARCHAR(100): Cadena de texto variable que optimiza almacenamiento para nombres de hasta 100 caracteres.
    categoria VARCHAR(50) NOT NULL,
    precio_unitario DECIMAL(10,2) NOT NULL,   -- DECIMAL(10,2): Exactitud numérica estricta para valores monetarios, evitando errores de redondeo de FLOAT.
    stock_actual INT NOT NULL,
    stock_minimo INT NOT NULL,
    fecha_ingreso DATE NOT NULL,              -- DATE: Almacena exclusivamente el componente de fecha (AAAA-MM-DD) sin consumo innecesario de hora/tiempo.
    activo TINYINT(1) DEFAULT 1               -- TINYINT(1): Representación booleana eficiente (1 = Disponible / 0 = Descontinuado).
);


-- ── SECCIÓN DML (Data Manipulation Language) ──────────────────────────

-- Paso 3: Carga inicial de datos de inventario
