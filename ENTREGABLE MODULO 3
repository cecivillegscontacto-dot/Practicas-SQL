-- Paso 4: Registro de ventas del día (Actualización de stock)
-- Venta de 3 unidades de Laptop Pro 15 (Stock inicial: 15 -> final: 12)
UPDATE inventario 
SET stock_actual = stock_actual - 3 
WHERE id_producto = 1;

-- Venta de 12 unidades de Mouse Inalámbrico (Stock inicial: 80 -> final: 68)
